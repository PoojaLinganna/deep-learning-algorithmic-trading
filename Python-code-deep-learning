        "                               'shares': shares, 'exit_date': None, 'exit_price': None, 'pnl': None})\n",
        "\n",
        "        elif signal == 'sell' and position > 0:\n",
        "            # Exit long: sell all shares\n",
        "            cash += position * price\n",
        "            pnl = position * (price - entry_price)\n",
        "            position = 0\n",
        "            # Complete the last open trade\n",
        "            for t in reversed(trades):\n",
        "                if t['exit_date'] is None:\n",
