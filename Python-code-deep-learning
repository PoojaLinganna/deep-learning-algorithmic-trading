        "def generate_reports(trades, daily_equity):\n",
        "    \"\"\"Print trade log, daily P&L, and yield curve.\"\"\"\n",
        "    # 1. Trade log\n",
        "    print(\"===== TRADE LOG =====\")\n",
        "    trades_df = pd.DataFrame(trades)\n",
        "    print(trades_df.to_string(index=False))\n",
        "    print()\n",
        "\n",
        "    # 2. Daily P&L (change in equity)\n",
        "    daily_equity['pnl'] = daily_equity['equity'].diff().fillna(0)\n",
        "    print(\"===== DAILY P&L (first 10 days) =====\")\n",
        "    print(daily_equity.head(10).to_string(index=False))\n",
        "    print()\n",
        "\n",
        "    # 3. Yield curve (cumulative return)\n",
        "    initial_capital = daily_equity['equity'].iloc[0]\n",
        "    daily_equity['cum_return'] = (daily_equity['equity'] / initial_capital - 1) * 100\n",
        "    print(\"===== YIELD CURVE (cumulative return %) =====\")\n",
        "    print(daily_equity[['date', 'cum_return']].to_string(index=False))\n",
        "\n",
        "    # Optional plot\n",
        "    plt.figure(figsize=(10, 5))\n",
        "    plt.plot(daily_equity['date'], daily_equity['cum_return'], label='Cumulative Return %')\n",
        "    plt.xlabel('Date')\n",
        "    plt.ylabel('Return (%)')\n",
        "    plt.title('Equity Curve (Yield Curve)')\n",
        "    plt.legend()\n",
        "    plt.grid(True)\n",
        "    plt.show()\n"
