        "def backtest(data, initial_capital=1_000_000):\n",
        "    \"\"\"\n",
        "    Simulate trading based on signals with position size ≤ 50% of equity\n",
        "    and whole shares only.\n",
        "    Returns:\n",
        "        trades: list of trade dictionaries\n",
        "        daily_equity: DataFrame with date and total equity\n",
        "    \"\"\"\n",
        "    cash = initial_capital\n",
        "    position = 0          # number of shares held (integer)\n",
        "    entry_price = 0.0\n",
        "    entry_date = None\n",
        "    trades = []\n",
        "    daily_records = []\n",
        "\n",
        "    # Ensure data is sorted by date\n",
        "    data = data.sort_values('date').reset_index(drop=True)\n",
        "\n",
        "    for idx, row in data.iterrows():\n",
        "        date = row['date']\n",
        "        price = row['price']\n",
        "        signal = row['signal']\n",
        "\n",
        "        # Process signals\n",
        "        if signal == 'buy' and position == 0:\n",
        "            # Enter long: use at most 50% of current cash\n",
        "            max_position_value = 0.5 * cash\n",
        "            shares = int(max_position_value / price)   # whole shares only\n",
        "            if shares > 0:\n",
        "                cash -= shares * price\n",
        "                position = shares\n",
        "                entry_price = price\n",
        "                entry_date = date\n",
        "                # Record entry (will complete on exit)\n",
